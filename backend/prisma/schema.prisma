// ============================================================
// Prisma Schema — ML-Ecommerce
// Database: PostgreSQL 15
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USERS & AUTHENTICATION
// ─────────────────────────────────────────

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  fullName       String?   @map("full_name") @db.VarChar(255)
  phone          String?   @db.VarChar(20)
  avatarUrl      String?   @map("avatar_url")
  role           UserRole  @default(customer)
  isActive       Boolean   @default(true) @map("is_active")
  emailVerified  Boolean   @default(false) @map("email_verified")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  refreshTokens       RefreshToken[]
  addresses           Address[]
  orders              Order[]
  cart                Cart?
  reviews             Review[]
  wishlists           Wishlist[]
  notifications       Notification[]
  userEvents          UserEvent[]
  recommendationLogs  RecommendationLog[]

  @@map("users")
}

enum UserRole {
  customer
  staff
  admin
  superadmin
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Address {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  fullName  String?  @map("full_name") @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  province  String?  @db.VarChar(100)
  district  String?  @db.VarChar(100)
  ward      String?  @db.VarChar(100)
  street    String?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ─────────────────────────────────────────
// PRODUCT CATALOG
// ─────────────────────────────────────────

model Category {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId    String?    @map("parent_id") @db.Uuid
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?
  imageUrl    String?    @map("image_url")
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  // Self-relation for parent/child categories
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]
  userEvents UserEvent[]

  @@map("categories")
}

model Brand {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  logoUrl     String?  @map("logo_url")
  description String?
  isActive    Boolean  @default(true) @map("is_active")

  products Product[]

  @@map("brands")
}

model Product {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId        String?  @map("category_id") @db.Uuid
  brandId           String?  @map("brand_id") @db.Uuid
  name              String   @db.VarChar(500)
  slug              String   @unique @db.VarChar(500)
  description       String?
  shortDescription  String?  @map("short_description")
  basePrice         Decimal  @map("base_price") @db.Decimal(15, 2)
  salePrice         Decimal? @map("sale_price") @db.Decimal(15, 2)
  costPrice         Decimal? @map("cost_price") @db.Decimal(15, 2)
  sku               String?  @unique @db.VarChar(100)
  stockQuantity     Int      @default(0) @map("stock_quantity")
  minOrderQuantity  Int      @default(1) @map("min_order_quantity")
  weight            Decimal? @db.Decimal(10, 3)
  tags              String[]
  metaTitle         String?  @map("meta_title") @db.VarChar(255)
  metaDescription   String?  @map("meta_description")
  isActive          Boolean  @default(true) @map("is_active")
  isFeatured        Boolean  @default(false) @map("is_featured")
  viewCount         Int      @default(0) @map("view_count")
  purchaseCount     Int      @default(0) @map("purchase_count")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  category    Category?          @relation(fields: [categoryId], references: [id])
  brand       Brand?             @relation(fields: [brandId], references: [id])
  images      ProductImage[]
  attributes  ProductAttribute[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  cartItems   CartItem[]
  reviews     Review[]
  wishlists   Wishlist[]
  userEvents  UserEvent[]

  @@index([categoryId], name: "idx_products_category")
  @@index([isActive], name: "idx_products_active")
  @@map("products")
}

model ProductImage {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  url       String
  altText   String? @map("alt_text") @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductAttribute {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId      String  @map("product_id") @db.Uuid
  attributeName  String  @map("attribute_name") @db.VarChar(100)
  attributeValue String  @map("attribute_value") @db.VarChar(255)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_attributes")
}

model ProductVariant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  variantName   String?  @map("variant_name") @db.VarChar(255)
  sku           String?  @unique @db.VarChar(100)
  price         Decimal? @db.Decimal(15, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")
  imageUrl      String?  @map("image_url")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@map("product_variants")
}

// ─────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────

model Order {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?       @map("user_id") @db.Uuid
  orderNumber     String        @unique @map("order_number") @db.VarChar(50)
  status          OrderStatus   @default(pending)
  paymentStatus   PaymentStatus @default(unpaid) @map("payment_status")
  paymentMethod   String?       @map("payment_method") @db.VarChar(30)
  shippingAddress Json?         @map("shipping_address")
  subtotal        Decimal?      @db.Decimal(15, 2)
  shippingFee     Decimal       @default(0) @map("shipping_fee") @db.Decimal(15, 2)
  discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount     Decimal?      @map("total_amount") @db.Decimal(15, 2)
  notes           String?
  couponCode      String?       @map("coupon_code") @db.VarChar(50)
  trackingNumber  String?       @map("tracking_number") @db.VarChar(100)
  shippedAt       DateTime?     @map("shipped_at") @db.Timestamptz
  deliveredAt     DateTime?     @map("delivered_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user       User?       @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]

  @@index([userId], name: "idx_orders_user")
  @@index([status], name: "idx_orders_status")
  @@map("orders")
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  unpaid
  paid
  refunded
  failed
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  productId    String?  @map("product_id") @db.Uuid
  variantId    String?  @map("variant_id") @db.Uuid
  productName  String?  @map("product_name") @db.VarChar(500)
  productImage String?  @map("product_image")
  quantity     Int
  unitPrice    Decimal? @map("unit_price") @db.Decimal(15, 2)
  totalPrice   Decimal? @map("total_price") @db.Decimal(15, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────
// CART
// ─────────────────────────────────────────

model Cart {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String?  @map("product_id") @db.Uuid
  variantId String?  @map("variant_id") @db.Uuid
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("cart_items")
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId           String   @map("product_id") @db.Uuid
  userId              String?  @map("user_id") @db.Uuid
  orderId             String?  @map("order_id") @db.Uuid
  rating              Int?
  title               String?  @db.VarChar(255)
  content             String?
  images              String[]
  isVerifiedPurchase  Boolean  @default(false) @map("is_verified_purchase")
  isApproved          Boolean  @default(false) @map("is_approved")
  adminReply          String?  @map("admin_reply")
  helpfulCount        Int      @default(0) @map("helpful_count")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  @@map("reviews")
}

// ─────────────────────────────────────────
// PROMOTIONS
// ─────────────────────────────────────────

model Coupon {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                 String    @unique @db.VarChar(50)
  description          String?
  discountType         String    @map("discount_type") @db.VarChar(20)
  discountValue        Decimal   @map("discount_value") @db.Decimal(15, 2)
  minOrderAmount       Decimal   @default(0) @map("min_order_amount") @db.Decimal(15, 2)
  maxDiscountAmount    Decimal?  @map("max_discount_amount") @db.Decimal(15, 2)
  usageLimit           Int?      @map("usage_limit")
  usedCount            Int       @default(0) @map("used_count")
  userLimit            Int       @default(1) @map("user_limit")
  applicableCategories String[]  @map("applicable_categories") @db.Uuid
  applicableProducts   String[]  @map("applicable_products") @db.Uuid
  startsAt             DateTime? @map("starts_at") @db.Timestamptz
  expiresAt            DateTime? @map("expires_at") @db.Timestamptz
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("coupons")
}

model FlashSale {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String?  @db.VarChar(255)
  startsAt DateTime? @map("starts_at") @db.Timestamptz
  endsAt   DateTime? @map("ends_at") @db.Timestamptz
  isActive Boolean  @default(true) @map("is_active")

  items FlashSaleItem[]

  @@map("flash_sales")
}

model FlashSaleItem {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flashSaleId   String    @map("flash_sale_id") @db.Uuid
  productId     String    @map("product_id") @db.Uuid
  salePrice     Decimal?  @map("sale_price") @db.Decimal(15, 2)
  quantityLimit Int?      @map("quantity_limit")

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id])

  @@map("flash_sale_items")
}

// ─────────────────────────────────────────
// ML: USER EVENTS (Event Tracking)
// ─────────────────────────────────────────

model UserEvent {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?    @map("user_id") @db.Uuid
  sessionId   String?    @map("session_id") @db.VarChar(100)
  productId   String?    @map("product_id") @db.Uuid
  categoryId  String?    @map("category_id") @db.Uuid
  eventType   EventType  @map("event_type")
  eventData   Json?      @map("event_data")
  ipAddress   String?    @map("ip_address")
  userAgent   String?    @map("user_agent")
  referrer    String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  user     User?     @relation(fields: [userId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([userId], name: "idx_user_events_user")
  @@index([productId], name: "idx_user_events_product")
  @@index([eventType], name: "idx_user_events_type")
  @@index([createdAt(sort: Desc)], name: "idx_user_events_created")
  @@map("user_events")
}

enum EventType {
  page_view
  product_view
  search
  add_to_cart
  remove_from_cart
  wishlist
  purchase
  review
  click_recommendation
}

// ─────────────────────────────────────────
// ML: RECOMMENDATIONS
// ─────────────────────────────────────────

model RecommendationLog {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String?  @map("user_id") @db.Uuid
  strategy             String?  @db.VarChar(50)
  contextCategoryId    String?  @map("context_category_id") @db.Uuid
  recommendedProducts  String[] @map("recommended_products") @db.Uuid
  clickedProductId     String?  @map("clicked_product_id") @db.Uuid
  converted            Boolean  @default(false)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@map("recommendation_logs")
}

model MlModel {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String?  @db.VarChar(100)
  version      String?  @db.VarChar(50)
  strategy     String?  @db.VarChar(50)
  mlflowRunId  String?  @map("mlflow_run_id") @db.VarChar(100)
  metrics      Json?
  isProduction Boolean  @default(false) @map("is_production")
  trainedAt    DateTime @default(now()) @map("trained_at") @db.Timestamptz

  @@map("ml_models")
}

// ─────────────────────────────────────────
// WISHLIST
// ─────────────────────────────────────────

model Wishlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String?  @db.VarChar(50)
  title     String?  @db.VarChar(255)
  message   String?
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
